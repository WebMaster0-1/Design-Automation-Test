{
  "mcpServers": {
    "storybook": {
      "command": "node",
      "args": [
        "mcp/storybook.mjs"
      ],
      "env": {
        "STORYBOOK_URL": "http://localhost:6006"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<YOUR_TOKEN_HERE>"
      }
    }
  }
}
# ──────────────────────────────────────────────────
# FMDQ Design Automation — Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to version control.

# Figma Personal Access Token
# Generate at: https://www.figma.com/settings → Personal Access Tokens
FIGMA_ACCESS_TOKEN=

# Figma File Key (from the URL of your Design System Kit file)
# e.g. https://www.figma.com/file/ABC123xyz/... → ABC123xyz
FIGMA_FILE_KEY=

# GitHub Personal Access Token (for automated PR creation / push)
# Generate at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=
